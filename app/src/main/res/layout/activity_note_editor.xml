<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/edit_note" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <EditText
            android:id="@+id/editTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="@string/title_hint"
            android:inputType="textCapSentences"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/transparent" />

        <!-- Formatting toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <Button
                android:id="@+id/btnBold"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:text="B"
                android:textStyle="bold"
                android:textSize="14sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="0dp"
                android:background="@drawable/bg_format_button"
                android:textColor="@color/format_button_text" />

            <Button
                android:id="@+id/btnItalic"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:text="I"
                android:textStyle="italic"
                android:textSize="14sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="0dp"
                android:background="@drawable/bg_format_button"
                android:textColor="@color/format_button_text" />

            <Button
                android:id="@+id/btnUnderline"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="U"
                android:textSize="14sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="0dp"
                android:background="@drawable/bg_format_button"
                android:textColor="@color/format_button_text" />

        </LinearLayout>

        <EditText
            android:id="@+id/editBody"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@null"
            android:gravity="top"
            android:hint="@string/body_hint"
            android:inputType="textCapSentences|textMultiLine"
            android:padding="16dp"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <!-- Divider above image strip -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/transparent" />

        <!-- Image strip (hidden when empty) -->
        <LinearLayout
            android:id="@+id/imageStripContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerImages"
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_weight="1"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Bottom bar: add photo + toggle-delete buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btnAddPhoto"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_add_photo"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add photo"
                app:tint="?attr/colorPrimary" />

            <ImageButton
                android:id="@+id/btnToggleDeleteImages"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle remove photos"
                android:visibility="gone"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
